---
layout: layouts/base.njk
---

<div class="post-card{% if linkedUrl %} linked-post{% endif %}">
<h1>
    {%- if linkedUrl %}
    <a href="{{ linkedUrl }}" class="linked-post-title u-bookmark-of" target="_blank" rel="noopener noreferrer">{{ title }} <svg class="linked-post-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg></a>
    {%- else %}
    {{ title }}
    {%- endif %}
</h1>
<ul class="post-metadata">
    <li>
        <time datetime="{{ page.date | htmlDateString }}">{{ page.date | smartDate }}</time>
    </li>
    <li class="reading-time">{{ content | readingTime }}</li>
    {%- for tag in tags | filterTagList %}
        {%- set tagUrl %}{{ site.baseUrl }}/tags/{{ tag | slugify }}/{% endset %}
        <li>
            <a href="{{ tagUrl }}" class="post-tag">{{ tag }}</a>
            {%- if not loop.last %},
            {% endif %}
        </li>
    {%- endfor %}
</ul>
{{ content | safe }}
<div class="share-actions">
{% include "mastodon-share.njk" %}
{%- set emailSubject = title -%}
{%- set emailUrl = page.url -%}
{% include "email-comment.njk" %}
</div>
</div>
{%- set related = collections.blogPosts | relatedPosts(tags, page.url, 3) %}
{%- if related.length > 0 %}
  <section class="related-posts">
    <h2>Related Posts</h2>
    <div class="related-posts-grid">
      {%- for rel in related %}
        <a href="{{ site.baseUrl }}{{ rel.url }}" class="related-post-card">
          <h3>{{ rel.data.title }}{% if rel.data.linkedUrl %} <svg class="linked-post-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>{% endif %}</h3>
          <time datetime="{{ rel.date | htmlDateString }}">{{ rel.date | smartDate }}</time>
          <span class="reading-time">{{ rel.templateContent | readingTime }}</span>
          {%- set relTags = rel.data.tags | filterTagList %}
          {%- if relTags.length > 0 %}
          <span class="card-tags">{%- for tag in relTags %}{%- if loop.index <= 3 %}<span>{{ tag }}</span>{%- endif %}{%- endfor %}{%- if relTags.length > 3 %}<span class="card-tags-more">+{{ relTags.length - 3 }}</span>{%- endif %}</span>
          {%- endif %}
          <p>{{ rel.data.summary if rel.data.summary else rel.templateContent | truncate(150) }}</p>
        </a>
      {%- endfor %}
    </div>
  </section>
{%- endif %}
{%- if collections.blogPosts %}
    {%- set previousPost = collections.blogPosts | getPreviousCollectionItem %}
    {%- set nextPost = collections.blogPosts | getNextCollectionItem %}
    {%- if nextPost or previousPost %}
        <ul class="links-nextprev">
            {%- if previousPost %}
                <li class="links-nextprev-prev">←
                    <a href="{{ site.baseUrl }}{{ previousPost.url }}">{{ previousPost.data.title }}</a>
                </li>
            {% endif %}
            {%- if nextPost %}
                <li class="links-nextprev-next">
                    <a href="{{ site.baseUrl }}{{ nextPost.url }}">{{ nextPost.data.title }}</a>
                    →</li>
            {% endif %}
        </ul>
    {%- endif %}
{%- endif %}
{% include "random-quote.njk" %}